# FilmFind Environment Configuration
# Copy this file to .env and fill in your values

# ── Database (Required) ────────────────────────────────────────────────────
# Supabase PostgreSQL — use session mode pooler (port 5432, NOT 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── LLM Provider (Required — at least one) ────────────────────────────────
# Primary LLM (free tier: 15 RPM / 1500 RPD)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback LLM
GROQ_API_KEY=your_groq_api_key_here

# ── TMDB API (Required) ───────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here

# ── Security (Required in production) ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# Bearer token for admin endpoints — leave empty to disable admin routes
ADMIN_SECRET=

# ── Cache ─────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
# For production, use Upstash Redis (leave empty to use Docker Redis)
# UPSTASH_REDIS_URL=rediss://:[password]@[host]:6379

# ── CORS (Required in production) ────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# In production, set to your deployed frontend URL:
# CORS_ORIGINS=https://your-app.vercel.app,https://filmfind.com

# ── Frontend (Required in production) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# In production, set to your deployed backend URL:
# NEXT_PUBLIC_API_URL=https://your-backend.huggingface.space
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co

# ── App Config ────────────────────────────────────────────────────────────
# Set DEBUG=false in production (disables --reload and OpenAPI docs)
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Background Jobs ───────────────────────────────────────────────────────
ENABLE_BACKGROUND_JOBS=false
